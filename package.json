{
	"name": "rbxts-package-template",
	"version": "1.0.0",
	"description": "Template for roblox-ts packages.",
	"keywords": ["rbxts", "roblox-ts"],
	"license": "MIT",
	"author": "",
	"type": "module",
	"main": "out/init.luau",
	"types": "out/index.d.ts",
	"files": ["out", "!**/*.tsbuildinfo", "!**/*.spec.lua", "!**/*.spec.d.ts", "!**/__tests__/**"],
	"scripts": {
		"build": "rbxtsc --verbose --type package",
		"build:dev": "lune run build-test-place",
		"dev": "lune run watch-test-place",
		"lint": "eslint --cache",
		"lint:ci": "eslint --cache --cache-strategy content",
		"lint:fix": "eslint --cache --fix",
		"prepack": "pnpm rbxtsc --type package --verbose",
		"prepare": "husky",
		"test": "pnpm build:dev && run-in-roblox --script scripts/run-tests.luau --place test.rbxl"
	},
	"dependencies": {
		"@flamework/core": "catalog:prod",
		"@rbxts/react": "catalog:prod",
		"@rbxts/react-roblox": "catalog:prod",
		"@rbxts/ui-labs": "catalog:dev"
	},
	"devDependencies": {
		"@commitlint/cli": "catalog:lint",
		"@commitlint/config-conventional": "catalog:lint",
		"@commitlint/prompt-cli": "catalog:lint",
		"@commitlint/types": "catalog:types",
		"@isentinel/eslint-config": "catalog:lint",
		"@rbxts/compiler-types": "catalog:types",
		"@rbxts/jest": "catalog:dev",
		"@rbxts/jest-globals": "catalog:dev",
		"@rbxts/types": "catalog:types",
		"eslint": "catalog:lint",
		"eslint-plugin-pnpm": "catalog:lint",
		"eslint-plugin-react-hooks": "catalog:lint",
		"eslint-plugin-react-x": "catalog:lint",
		"husky": "catalog:script",
		"jiti": "catalog:script",
		"rbxts-transform-debug": "catalog:build",
		"rbxts-transform-env": "catalog:build",
		"rbxts-transformer-flamework": "catalog:build",
		"roblox-ts": "catalog:build",
		"ts-plugin-sort-import-suggestions": "catalog:types",
		"typescript": "catalog:build"
	},
	"packageManager": "pnpm@10.28.2"
}
